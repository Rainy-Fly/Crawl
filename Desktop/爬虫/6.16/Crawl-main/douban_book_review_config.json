{
  "type": "crawler",
  "name": "豆瓣书评爬虫",
  "description": "爬取豆瓣图书页面的书评信息，包括评分、评论内容、评论者等",
  "urls": [
    "https://book.douban.com/subject/1084336/comments/",
    "https://book.douban.com/subject/2567698/comments/"
  ],
  "selectors": {
    "book_info": {
      "title": "h1 span",
      "rating": "#interest_sectl .rating_num",
      "author": "#info a:first-of-type"
    },
    "review_list": ".comment-item",
    "review_item": {
      "user": ".comment-info a",
      "rating": ".comment-info .rating",
      "date": ".comment-info .comment-time",
      "content": ".short",
      "full_content": ".hide-block .full",
      "useful_count": ".action .vote-count",
      "reply_count": ".action .reply-count"
    },
    "pagination": {
      "current_page": ".thispage",
      "next_page": ".next a"
    }
  },
  "headers": {
    "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36",
    "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,image/webp,*/*;q=0.8",
    "Accept-Language": "zh-CN,zh;q=0.9,en;q=0.8",
    "Referer": "https://book.douban.com/"
  },
  "delay": 3,
  "max_pages": 5,
  "timeout": 60,
  "retry_times": 3,
  "retry_delay": 5,
  "encoding": "utf-8"
}
